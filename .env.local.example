# AI Hook Lab 环境变量配置
# 复制此文件为 .env.local 并填入你的配置

# [必填] OpenAI 兼容 API 密钥
# 支持 OpenAI / DeepSeek / 通义千问 / 智谱 等所有兼容 OpenAI 格式的服务
AI_API_KEY=sk-your-api-key

# [必填] API 基础 URL
# 常用服务商示例（替换 your-api-endpoint 为实际地址）:
# OpenAI:   https://your-api-endpoint.com/v1
# DeepSeek: https://your-api-endpoint.com/v1
# 通义千问:  https://your-api-endpoint.com/compatible-mode/v1
# 智谱:     https://your-api-endpoint.com/api/paas/v4
AI_BASE_URL=https://your-api-endpoint.com/v1

# [必填] 模型名称
# 取决于你使用的服务商，常用值：gpt-4o / deepseek-chat / qwen-turbo / glm-4
AI_MODEL=gpt-4o
